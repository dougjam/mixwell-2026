---
import { withBase, isExternal } from '../lib/paths';

interface Props {
  href: string;
  title: string;
  blurb?: string;
  thumbnail?: string;
  thumbAlt?: string;
  tag?: string;
}

const { href, title, blurb, thumbnail, thumbAlt, tag } = Astro.props;
const external = isExternal(href);
const resolvedHref = external ? href : withBase(href);
const imgSrc = thumbnail ? withBase(thumbnail) : null;
---

<a
  class="card"
  href={resolvedHref}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  {
    imgSrc && (
      <div class="card__thumb">
        <img src={imgSrc} alt={thumbAlt ?? ''} loading="lazy" />
        {tag && <span class="card__tag">{tag}</span>}
      </div>
    )
  }
  <div class="card__body">
    <h3 class="card__title">
      {title}
      {external && <span class="card__ext" aria-hidden="true">↗</span>}
    </h3>
    {blurb && <p class="card__blurb">{blurb}</p>}
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    color: inherit;
    box-shadow: var(--shadow);
    transition:
      transform 0.15s ease,
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }
  .card:hover {
    text-decoration: none;
    transform: translateY(-2px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }
  .card__thumb {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--bg-subtle);
    overflow: hidden;
  }
  .card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card__tag {
    position: absolute;
    top: var(--space-2);
    left: var(--space-2);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.1em 0.6em;
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--text-muted);
  }
  .card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .card__title {
    font-size: var(--step-1);
    margin: 0;
  }
  .card__ext {
    font-size: 0.7em;
    color: var(--text-faint);
    margin-left: 0.2em;
  }
  .card__blurb {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--step--1);
    line-height: 1.5;
  }
</style>
