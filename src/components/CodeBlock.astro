---
import { Code } from 'astro:components';

// Syntax-highlighted code with a copy button. `code` is the raw source string;
// `lang` is a Shiki language id (e.g. glsl, hlsl, c, cpp, bash).
interface Props {
  code: string;
  lang?: string;
}
const { code, lang = 'text' } = Astro.props;
---

<div class="codeblock" data-code={code}>
  <button class="btn codeblock__copy" type="button" data-copy>Copy</button>
  <Code code={code} lang={lang as any} theme="github-dark" />
</div>

<style>
  .codeblock {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .codeblock__copy {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    z-index: 1;
    opacity: 0.85;
  }
  .codeblock__copy:hover {
    opacity: 1;
  }
  .codeblock :global(pre) {
    margin: 0;
    padding: var(--space-4);
    overflow-x: auto;
    font-size: var(--step--1);
    line-height: 1.55;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.codeblock').forEach((block) => {
    const btn = block.querySelector<HTMLButtonElement>('[data-copy]');
    btn?.addEventListener('click', async () => {
      const code = block.dataset.code ?? '';
      try {
        await navigator.clipboard.writeText(code);
        const prev = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => (btn.textContent = prev), 1500);
      } catch {
        btn.textContent = 'Copy failed';
      }
    });
  });
</script>
