---
import { withBase } from '../lib/paths';
import type { ShaderEntry } from '../lib/data';

interface Props {
  entry: ShaderEntry;
}
const { entry } = Astro.props;
const thumb = withBase(entry.thumbnail);
---

<a
  class="stcard"
  href={entry.viewUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`Open "${entry.title}" on Shadertoy (new tab)`}
>
  <div class="stcard__thumb">
    <img src={thumb} alt="" loading="lazy" />
    <span class="stcard__st" title="Opens on Shadertoy" aria-hidden="true">ST ↗</span>
  </div>
  <div class="stcard__body">
    <h3 class="stcard__title">{entry.title}</h3>
    <p class="stcard__exp muted">{entry.explanation}</p>
  </div>
</a>

<style>
  .stcard {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
    box-shadow: var(--shadow);
    color: inherit;
    transition:
      transform 0.15s ease,
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }
  .stcard:hover {
    text-decoration: none;
    transform: translateY(-2px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }
  .stcard__thumb {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--bg-subtle);
  }
  .stcard__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .stcard__st {
    position: absolute;
    bottom: var(--space-2);
    right: var(--space-2);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.05em 0.45em;
    font-size: var(--step--1);
    font-weight: 700;
    color: var(--text-muted);
  }
  .stcard__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .stcard__title {
    font-size: var(--step-1);
    margin: 0;
  }
  .stcard__exp {
    font-size: var(--step--1);
    margin: 0;
  }
</style>
