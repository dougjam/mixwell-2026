// Line RDF helper function: "useS" switches between Series or Elliptic function versions.
// CONFIRMED: Both are awesome but cost(E) ~ 15 cost(S)
float2 rdLineSE(float2 p, float r, float2 dir, bool useS)
{
    dir = normalize(dir);
    float2 n = rot90(dir); //float2(-dir.y, +dir.x);
    float height = dot(p, n);
    return useS ? rdLine1DS(height, r) * dir : rdLine1DE(height, r) * dir;
}


