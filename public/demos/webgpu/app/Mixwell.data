// Returns a 2x2 matrix constructed from v and epsilon using the Mixwellet kernel
float2x2 getFDMixwellMatrixPOW(float2 v, float eps)
{
    float R2 = dot(v, v);
    float R = sqrt(R2);
    float e2 = eps * eps;
    float d = pow(R2 + e2, 1.5f); //  ＼（⊙.☉）／

    float Afd = 1.0f - (R * (R2 + 2.f * e2)) / d;
    float Bfd = e2 / (R * d);

    float2x2 K = float2x2(Afd, 0.0, 0.0, Afd) + Bfd * outerProduct(v, v);
    return K;
}
 */

