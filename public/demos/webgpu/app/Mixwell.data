BasedOnStyle: Microsoft

# --- Indentation: match VS defaults ---
IndentWidth: 4
TabWidth: 4
UseTab: Never
ContinuationIndentWidth: 4

# --- Braces: Allman, like your original ---
BreakBeforeBraces: Allman

# --- Do not rewrap code ---
ColumnLimit: 0

# --- Prevent function header breakage ---
BreakAfterReturnType: None
AlwaysBreakAfterReturnType: None
PenaltyReturnTypeOnItsOwnLine: 1000000
PenaltyBreakBeforeFirstCallParameter: 1000000
AllowAllParametersOfDeclarationOnNextLine: false
BinPackParameters: true
BinPackArguments: true

# --- Reduce formatting churn ---
ReflowComments: false
SortIncludes: Never
AlignConsecutiveAssignments: None
AlignConsecutiveDeclarations: None
AlignTrailingComments: false

# --- Spacing ---
SpacesInParentheses: false
SpacesInCStyleCastParentheses: false
SpaceBeforeParens: ControlStatements
#include "MixwellCommon.hlsl"

Texture2D<float2> gOffsetTex;
Texture2D<float4> gInputTex;
Texture2D<float4> gInputHistoryTex;
RWTexture2D<float4> gOutputHistoryTex;
SamplerState gSampler;

#define TILING_MODE_CLAMP 0
#define TILING_MODE_WRAP 1
#define TILING_MODE_MIRROR 2
#define TILING_MODE_BORDER 3

cbuffer AccumulateCB
{
    uint ImageSource;
    float SampleWeight;
    uint2 InputSize;
    uint OffsetTexValid;
    uint NumSamples;
    uint2 InputTextureSize;
    float3 BorderColor;
    uint TilingMode;
    float2 PatternOffset;
    float PatternScale;
}

float3 sampleInputTexture(float2 p)
{
    p += InputTextureSize / 2; // center the pattern (integer division to avoid sub-pixel offset which will cause blurring)
    
    float2 uv = p / InputTextureSize;
    switch (TilingMode)
    {
    case TILING_MODE_CLAMP:
        uv = clamp(uv, 0, 1);
        break;
    case TILING_MODE_WRAP:
        uv = frac(uv);
        break;
    case TILING_MODE_MIRROR:
        uv = abs(frac(uv * 0.5 - 0.5) * 2 - 1);
        break;
    case TILING_MODE_BORDER:
        if (any(uv < 0) || any(uv > 1))
            return BorderColor;
        break;
    }
    
    uv.y = 1.0 - uv.y; // need to flip vertically
    return gInputTex.SampleLevel(gSampler, uv, 0);
}

float3 displacementColors(float2 d)
{
    const float scale = 0.002;
    return float3(abs(d.x) * scale, 0, abs(d.y) * scale);
}

float4 SampleSource(float2 p, float2 pNoDisplacement)
{
    float2 d = p - pNoDisplacement;
    p += PatternOffset;
    
    [branch]
    switch (ImageSource)
    {
    case IMAGE_SOURCE_TEXTURE:
        return float4(sampleInputTexture(p), 1);
    case IMAGE_SOURCE_PROCEDURAL_A:
        return float4(paintBlobs(p * PatternScale + 0.5), 1);
    case IMAGE_SOURCE_PROCEDURAL_B:
        return float4(paintChocolate(p * PatternScale + 0.5), 1);
        //paintCheckerboard(p * PatternScale, 0.1f);
        //paintTestImage(p);
        //paintTestSquare(p * PatternScale);
    case IMAGE_SOURCE_DOT:
        return float4((length(p) < 100).xxx, 1);
    case IMAGE_SOURCE_DISPLACEMENT:
        return float4(displacementColors(d), 1);
    }
    
    return 0;
}

[numthreads(8, 8, 1)]
void CSMain(uint3 tid : SV_DispatchThreadID)
{
    if (any(tid.xy >= Params.BufferSize))
        return;
    
    float2 pixelCoord = tid.xy;
    float2 pq = ScreenToWorldSpace(pixelCoord + R2Sequence(NumSamples));
    float2 p;
    if (OffsetTexValid)
    {
        p = pq + gOffsetTex[tid.xy % InputSize];
    }
    else
    {
        p = pq;
    }
    float4 existingColor = SampleWeight >= 1 ? 0 : gInputHistoryTex[tid.xy];
    float4 newCol = SampleSource(p, pq);
    gOutputHistoryTex[tid.xy] = lerp(existingColor, newCol, SampleWeight);
}#include "MixwellCommon.hlsl"

struct VSOut
{
    float4 pos : SV_Position;
    float2 uv  : TEXCOORD0;
};

VSOut VSMain(uint vid : SV_VertexID)
{
    float2 verts[3] = {
        float2(-1.0, -1.0),
        float2(-1.0,  3.0),
        float2( 3.0, -1.0)
    };

    VSOut o;
    o.pos = float4(verts[vid], 0.0, 1.0);
    o.uv  = 0.5 * (o.pos.xy + 1.0);
    return o;
}

Texture2D    gInputTex;
SamplerState gSampler;

float4 PSMain(VSOut IN) : SV_Target
{
    return gInputTex.Sample(gSampler, IN.uv);
}
