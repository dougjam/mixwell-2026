// Curve brush reverse-drift evaluation. Unmasked impl due to general [tStart,tEnd].
template<
typename ICurve>
float2 rdCurve(float2 p0, float r, ICurve curve, float tStart, float tEnd)
{
    float2 p = p0; // reverse-drifted point position (init: p0)
    
    float tLeft = abs(tEnd - tStart);
    float tDir = sign(tStart - tEnd); // rev (end --> start)
    float t = tEnd; // reverse flow
    while (tLeft > 0.f)
    {
        float2 b0 = curve.icurveEval(t); // brush pos at t
        float2 v = p - b0; // rel pos from end brush goal
        float R = length(v);
        float dLAdapt = 0.10f * max(r, R); // adaptive stepsize

        float dt = tDir * min(tLeft, curve.icurveDTMax); // signed max dt without adaptation
        float2 b1 = curve.icurveEval(t + dt);
        float2 db = b1 - b0; // Δbrush 
        float dbLength = length(db);
        if (dbLength > dLAdapt) // Reduce stepsize adaptively
        {
            dt *= dLAdapt / dbLength; // scale down
            b1 = curve.icurveEval(t + dt);
            db = b1 - b0; // Δbrush 
        }
        
        float2x2 K = getMixwellBrushMatrix(v, r); // K(v)
        float2 dp = mul(K, db); // Euler approx, dp = K(v) db
        p += dp;
        t += dt; // signed update
        tLeft -= abs(dt);
    }

    return (p - p0);
}

// Reverse drift of curve brush for t∈[0→1] using distance-based masking.
template<
typename ICurve>
float2 rdCurve01Masked(float2 p0, float r, ICurve curve)
{
    float2 p = p0;
    float d = max(0.f, length(p) - curve.icurve01Radius); // Distance to curve01 disk bound.
    const float dMax = RDSEGMENT_MASK_R_FACTOR * r; // for masking
    if (d < dMax) // masked rdCurve eval
    {
        float mask = (1.f - smoothstep(0.5f * dMax, dMax, d));
        p += mask * rdCurve(p, r, curve, 0.f, 1.f);
    }
    return (p - p0);
}

// ICurve Circle at origin.
struct crvCircle
{
    float radius; // circle param
    float icurveDTMax; // [ICurve] Maximum dt for rd curve evaluation.
    float icurve01Radius; // [ICurve] Bounding disk radius for t∈[0,1] curve (assuming center at origin).
    float angleStart;
            
    // [ICurve] Evaluates CCW circle for t∈[0→1].
    float2 icurveEval(float t)
    {
        float angle = angleStart + TWO_PI * t;
        float s, c;
        sincos(angle, s, c);
        return radius * float2(c, s);
    }
    // Want icurveEvalTangent(t) for rd midpoint integration
};
// ICurve Line Segment loop at origin.
struct crvSegment
{
    float radius; // half-length param
    float icurveDTMax; // [ICurve] Maximum dt for rd curve evaluation.
    float icurve01Radius; // [ICurve] Bounding disk radius for t∈[0,1] curve (assuming center at origin).
    
    // Fast quartic sin(2πx) approximation (no XU load). Assumes x∈[0,1].
    float fastSin01(float x)
    {
        x = 1.0f - 2.0f * x;
        float parabola = 4.0f * x * (1.0f - abs(x));
        return parabola * (0.775f + 0.225f * abs(parabola));
    }
            
    // [ICurve] Evaluates line segment loop for t∈[0→1]. Assumes x∈[0,1].
    float2 icurveEval(float t)
    {
        //float wave = 1.0 - 4.0 * abs(frac(t) - 0.5); // triwave: [0,1]→[-1,1]
        //float wave = sin(TWO_PI * t); // sinewave: [0,1]→[-1,1]
        float wave = fastSin01(t); // approx sinewave: [0,1]→[-1,1]
        return radius * float2(0.f, wave);
    }
    // Want icurveEvalTangent(t) for rd midpoint integration
};

template<
typename ICurve>
float2 rdCurveGrid(float2 p, float r, ICurve curve, float gridSize)
{
    float2 p0 = p;
    const float dMax = RDSEGMENT_MASK_R_FACTOR * r; // for masking
    
    float2 pIJ = round(p / gridSize);
    float dI = ceil((dMax + curve.icurve01Radius) / gridSize) + 1;
    for (float i = pIJ.x - dI; i <= pIJ.x + dI; i += 1.f)
    {
        for (float j = pIJ.y - dI; j <= pIJ.y + dI; j += 1.f)
        {
            float2 q = p - gridSize * float2(i, j); // use p0 for drift superposition.
            p += rdCurve01Masked(q, r, curve);
        }
    }
    return (p - p0);
}

float2 rdCircleGrid(float2 p, float r, float circleRadius, float gridSize)
{
    crvCircle C;
    C.radius = circleRadius;
    C.angleStart = PI_2;
    C.icurve01Radius = circleRadius;
    C.icurveDTMax = 1.f / 16.f;
    return rdCurveGrid(p, r, C, gridSize);
}

// ICurve translator
template<
typename ICurve>
struct CurveTranslator
{
    ICurve curve;
    float icurveDTMax; // [ICurve] Maximum dt for rd curve evaluation.
    float icurve01Radius; // [ICurve] Bounding disk radius for t∈[0,1] curve (assuming center at origin).
    float2 icurve01Translation; // Animated translation, trans*(t-½)
    float2x2 icurveRotation; // Fixed rotation applied to underlying curve used to follow translation direction.
    
    void init(ICurve C, float2 trans, bool makeTransRotate)
    {
        curve = C;
        icurveDTMax = C.icurveDTMax;
        icurve01Radius = C.icurve01Radius + 0.5f * length(trans);
        icurve01Translation = trans;
        
        // Compute rotation compensation: 
        float2 n = (makeTransRotate) ? normalize(trans) : float2(1.f, 0.f);
        //float c = n.x;    float s = n.y;
        icurveRotation = float2x2(n.x, -n.y, n.y, n.x); // CCW Rotation | Identity.
    }
            
    // [ICurve] Evaluates R*curve(t) + trans*(t-½)
    float2 icurveEval(float t)
    {
        return mul(icurveRotation, curve.icurveEval(t)) + icurve01Translation * (t - 0.5);

    }
    // Impl. icurveEvalTangent(t) for rd midpoint integration
};

    
/**
 * Curve Wave RDF. 
 * 
 * Uses rdCurve * translation to construct a curve wave parameterized with user specified direction and parameters.
 * Uses sparse evaluation of masked rdCurves only near p.
 * 
 * Inputs: 
 *  p   - Evaluation point.
 *  r   - Tine radius.
 *  dir - Direction of wave centerline (unit vector).
 *  L   - Wavelength
 *  A   - Amplitude 
 */ 
// Evaluates curve for t∈[0,1] translated along each wavelength, L.
template<
typename ICurve>
float2 rdCurveWave(float2 p0, float r, ICurve curve, float2 dir, float L, float A)
{
    // Input de-amplitude scaling: In the key of 1/A...
    float invA = 1.f / A;
    p0 *= invA;
    r *= invA;
    L *= invA;
    
    float2 p = p0;
    
    float2 trans = L * dir;
    CurveTranslator < ICurve > C;
    C.init(curve, trans, true);
    
    // Project p onto line --> c and get coords for p as (x, y)
    
    float x = dot(p, dir);
    float2 c = x * dir;
    float y = length(p - c); // Unsigned distance to line
    float segR = C.icurve01Radius;
    float R = r * RDSEGMENT_MASK_R_FACTOR + segR; // Bounding radius of point w.r.t. qi
    float Rx = sqrt(R * R - y * y); // Influence "radius" about x on line
    int iR = (int) ceil((x + Rx) / L); // max i
    int iL = (int) floor((x - Rx) / L); // min i 
    
    /// ESTIMATE INITIAL RANGE [iL,iR] USING p0: 
    /// Reverse process rdCurve segments, iR→iL, then continue past iL until out of range, |p-ci|>R.
    for (int i = iR; i >= iL; i--)
    { // Reverse sweep
        float2 centeri = trans * float(i);
        p += rdCurve01Masked(p - centeri, r, C);
    }
    {// Process until out of range, |p-ci|>R
        float R2 = R * R;
        for (int i = iL - 1; i > iL - 100; i--)
        {
            float2 vi = p - trans * float(i);
            if (dot(vi, vi) > R2) // out of range
                break;
            p += rdCurve01Masked(vi, r, C);
        }
    }
    
    return A * (p - p0); // Output amplitude-scaled rd. Rock on.
}
// Unit amplitude (A=1) rdCurveWave.
template<
typename ICurve>
float2 rdCurveWave(float2 p0, float r, ICurve curve, float2 dir, float L)
{
    return rdCurveWave(p0, r, curve, dir, L, 1.f);
}

template<
typename ICurve>
float2 rdCurveWaveComb(float2 p, float r, ICurve curve, float2 dir, float L, float A, float combGap)
{
    dir = normalize(dir);
    float2 n = rot90(dir);
    float y = dot(p, n);
    float R = A * curve.icurve01Radius + r * RDSEGMENT_MASK_R_FACTOR; // 1D perp-influence radius of a wave centerline
    int dk = (int) ceil(R / combGap); // Conservative range of wave indices influencing p 
    int kp = (int) round(y / combGap); // Closest wave index (where origin wave is k=0)
  
    float2 rdf = float2(0.f, 0.f);
    for (int k = kp - dk; k <= kp + dk; k++)
    { // Sum nearby(p) wave RDFs: (non-overlapping paths -- it's a comb)
        float yk = float(k) * combGap; // Perp offset of k'th centerline 
        float2 pk = p - yk * n; // Translate k'th wave to origin
        rdf += rdCurveWave(pk, r, curve, dir, L, A); // Accumulate RDF of k'th triwave 
    }
    return rdf;
}

float2 rdSineWaveComb(float2 p, float r, float2 dir, float L, float A, float combGap)
{
    crvSegment C; // sine-y segment
    C.radius = 1.f;
    C.icurve01Radius = 1.f;
    C.icurveDTMax = 1.f / 24.f;
    return rdCurveWaveComb(p, r, C, dir, L, A, combGap);
}
#endif

void SandboxPass(inout float2 p, float sandboxParams[8])
{
    float2 mouse = Params.iMouse.xy / float2(Params.BufferSize);
    
    float C0 = sandboxParams[0];
    float C1 = sandboxParams[1];
    float C2 = sandboxParams[2];
    float C3 = sandboxParams[3];
    float C4 = sandboxParams[4];
    float r = max(1, C0);
    float2 a = float2(0, 0);
    float2 b = float2(C1, C2);
    
#if !NO_TEMPLATES
    if (true)
    {
        float L = max(50, C3);
        float A = max(10.f, C2); // ampl scaling of curve 
        float combGap = max(50, C4);
        p += rdSineWaveComb(p, r, float2(1.f, 0.f), L, A, combGap);
    }
    
    if (false) // CIRCLE WAVES + GRIDS:
    {
        //crvCircle C;
        //C.angleStart = 0.f; //        PI_2;

        crvSegment C;
        
        C.radius = max(10, C1);
        C.icurve01Radius = C.radius;
        C.icurveDTMax = 1.f / 32.f;
        
        float A = 1.f + 0.01 * max(0.f, C2); // ampl scaling of curve 
        if (false)
        {
            p += A * rdCurve(p / A, r / A, C, 0.f, 1.f); // basic curve.  (r/A to preserve brush radius)
        }
        
        if (false) // CURVE WAVE: (use 3 sliders: r, R, L)
        {
            float2 trans = float2(max(50, C3), 0.f);
            //p += A * rdCurveWave(p / A, r / A, C, normalize(trans), length(trans) / A);
            p += rdCurveWave(p, r, C, normalize(trans), length(trans), A);
        }
        
        if (false) // 0:r, 1:Cr, 2:A, 3:L, 4:Gap
        {
            float2 trans = float2(max(50, C3), 0.f);
            float combGap = max(50, C4);
            p += rdCurveWaveComb(p, r, C, normalize(trans), length(trans), A, combGap);
        }
                
        if (true) // CURVE GRID
        {
            float circleRadius = max(5.0f, C1);
            float gridSize = max(10.0f, C2);
            p += rdCircleGrid(p, r, circleRadius, gridSize);
        }
    }
#endif

    if (false) // rdLineSE compare
    {
        for (float y = -500.f; y <= 500.f; y += 50.f)
        {
            bool useSeries = (p.y > 0.f);
            p += rdLineSE(p - float2(0, y), r, float2(1, 0), useSeries);
        }
        if (abs(p.y) < 5.)
        {
            p = float2(0, 0);
            return;
        }
    }

    bool isStripeX = sin(6.28f * p.x / 10.f) > 0.f;
    if (isStripeX)
    {
	//p += rdSegmentM(p, r, a, b);
	//rdMixwellBrushAdaptive(p, r, a, b, 0.1f);
    }
    else
    {
	//p += rdSegment(p, r, a, b);
	//p += myrdSegmentT(p, r, a, b);
	//p += rdMixwellBrushAdaptive(p, r, a, b, 0.1f);
    }
    
    if (false)
    {
        if (isStripeX)
        {
            p += rdLine(p, r, float2(1.f, 0.f));
            //rdMixwellBrushAdaptive(p, r, a, b, 0.1f);
        }
        else
        {
            float2 a = float2(-C3, 0.f);
            float2 b = -a;
            //p += rdSegmentM(p, r, a, b);
            p += rdSegmentT(p, r, a, b);
            //p += rdMixwellBrushAdaptive(p, r, a, b); 
            //p += rdMixwellBrushAdaptiveMidpoint(p, r, a, b);
        }
    }


}